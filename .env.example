# Guardei - Exemplo de Variáveis de Ambiente

# ===== BANCO DE DADOS =====
DB_USER=guardei_user
DB_PASSWORD=guardei_password
DB_HOST=db
DB_PORT=3306
DB_NAME=guardei_db

# URL completa do banco de dados (Prisma)
DATABASE_URL="mysql://guardei_user:guardei_password@db:3306/guardei_db"

# ===== SERVIDOR =====
PORT=3001
NODE_ENV=production

# ===== FRONTEND =====
VITE_API_URL=http://backend:3001
